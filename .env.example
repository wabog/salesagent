APP_ENV=development
DATABASE_URL=sqlite+aiosqlite:///./sales_agent.db
MESSAGE_BATCH_WINDOW_SECONDS=3
# Producción con Postgres:
# DATABASE_URL=postgresql+asyncpg://usuario:password@host:5432/sales_agent
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CRM_BACKEND=notion
NOTION_API_KEY=
NOTION_DATA_SOURCE_ID=329894f4-b535-806f-92aa-000b0823c421
NOTION_VERSION=2025-09-03
NOTION_PHONE_PROPERTY=Telefono
NOTION_NAME_PROPERTY=Nombre
NOTION_STAGE_PROPERTY=Etapa
NOTION_NOTES_PROPERTY=Notas
NOTION_EMAIL_PROPERTY=Email
NOTION_FOLLOWUP_SUMMARY_PROPERTY=Resumen seguimiento
NOTION_NEXT_ACTION_PROPERTY=Próxima acción
NOTION_LAST_CONTACT_PROPERTY=Último contacto
KAPSO_BASE_URL=https://api.kapso.ai
KAPSO_PHONE_NUMBER_ID=
KAPSO_API_TOKEN=
WHATSAPP_SEND_ENABLED=false
# Si APP_ENV=production y no defines PLAYGROUND_ENABLED, el playground queda apagado.
# PLAYGROUND_ENABLED=true
# PLAYGROUND_TOKEN=cambia-esto-por-un-secreto-largo
